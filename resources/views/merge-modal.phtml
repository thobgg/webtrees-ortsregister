use Fisharebest\Webtrees\I18N;
use Ortsregister\Dto\SidecarInventory;
use Ortsregister\Dto\SubtagConflict;

$renderInventory = static function (SidecarInventory $inv): string {
    if ($inv->isEmpty()) {
        return '<span class="text-muted"><i class="fas fa-folder me-1"></i>'
            . I18N::translate('Keine kuratierten Daten') . '</span>';
    }
    $badges = [];
    if ($inv->govLinked) {
        $badges[] = '<span class="badge bg-info-subtle text-info-emphasis me-1">'
            . I18N::translate('GOV verknüpft') . '</span>';
    }
    if ($inv->markdownFiles > 0) {
        $badges[] = '<span class="badge bg-light text-dark me-1">'
            . I18N::translate('%s Notizen', (string) $inv->markdownFiles) . '</span>';
    }
    if ($inv->kbs > 0) {
        $badges[] = '<span class="badge bg-light text-dark me-1">'
            . I18N::translate('%s Kirchenbücher', (string) $inv->kbs) . '</span>';
    }
    if ($inv->tasks > 0) {
        $badges[] = '<span class="badge bg-light text-dark me-1">'
            . I18N::translate('%s Aufgaben', (string) $inv->tasks) . '</span>';
    }
    if ($inv->digitalisate > 0) {
        $badges[] = '<span class="badge bg-light text-dark me-1">'
            . I18N::translate('%s Digitalisate', (string) $inv->digitalisate) . '</span>';
    }
    return implode('', $badges);
};

?>
<div class="modal-header">
