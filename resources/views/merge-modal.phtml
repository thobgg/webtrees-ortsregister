<?php

/**
 * View: ortsregister::merge-modal  (AJAX-Fragment für Bootstrap-Modal-Body)
 *
 * @var \Ortsregister\Dto\MergeAnalysis $analysis
 * @var \Fisharebest\Webtrees\Tree      $tree
 * @var bool                            $autoAcceptEditsActive
