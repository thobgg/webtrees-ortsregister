<?php if ($tree !== null) : ?>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const table = document.getElementById('orte-datatable');
    if (!table || typeof $.fn.dataTable === 'undefined') return;

    const dt = $(table).dataTable({
        ajax:       { url: table.dataset.ajax, type: 'GET' },
        serverSide: true,
        processing: true,
        language: {
            search:      '<?= e(I18N::translate('Suchen:')) ?>',
            lengthMenu:  '<?= e(I18N::translate('_MENU_ Einträge')) ?>',
            info:        '<?= e(I18N::translate('_START_–_END_ von _TOTAL_')) ?>',
            infoEmpty:   '<?= e(I18N::translate('Keine Einträge')) ?>',
            zeroRecords: '<?= e(I18N::translate('Keine Treffer')) ?>',
            processing:  '<?= e(I18N::translate('Wird geladen …')) ?>',
            paginate: { first: '«', last: '»', next: '›', previous: '‹' },
        },
        columns: [
            { orderable: false, searchable: false, className: 'text-center', visible: false },
            { orderable: true,  searchable: true  },
            { orderable: true,  searchable: false, className: 'text-end' },
            { orderable: false, searchable: false, className: 'text-center' },
            { orderable: false, searchable: false, className: 'text-center' },
        ],
        order:      [[1, 'asc']],
        pageLength: 50,
        lengthMenu: [10, 25, 50, 100],
        dom: '<"d-flex justify-content-between mb-2"lf>rt<"d-flex justify-content-between mt-2"ip>',
        drawCallback: function () {
            // Nach jedem Render: Radios gemäß aktuellem State wieder anhaken
            restoreSelectionRadios();
        },
    });

    // ---- GOV-Verknüpfen-Button (Event-Delegation, überlebt DT-Re-Render) ----
    table.addEventListener('click', function (e) {
        const btn = e.target.closest('.ortsregister-gov-btn');
        if (!btn) return;
        const placeId = btn.dataset.placeId;
        const url = appendQuery(table.dataset.govLink, 'place_id=' + placeId);
        const content = document.getElementById('ortsregister-merge-modal-content');
        content.innerHTML = '<div class="modal-body text-center py-5"><div class="spinner-border text-primary"></div></div>';
        new bootstrap.Modal(document.getElementById('ortsregister-merge-modal')).show();
        fetch(url, { headers: { 'Accept': 'text/html' }})
            .then(r => r.text())
            .then(html => { content.innerHTML = html; })
            .catch(err => { content.innerHTML = '<div class="modal-body text-danger">Fehler: ' + err + '</div>'; });
    });

    // ---- GOV-Form Submit + Unlink (Event-Delegation) ----
    document.addEventListener('submit', function (e) {
        if (e.target.id !== 'ortsregister-gov-form') return;
        e.preventDefault();
        const form = e.target;
        fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { 'X-CSRF-TOKEN': table.dataset.csrf },
        })
        .then(r => r.json())
        .then(data => {
            const content = document.getElementById('ortsregister-merge-modal-content');
            if (data.success) {
                content.innerHTML = '<div class="modal-header"><h5 class="modal-title text-success">'
                    + '<i class="fas fa-check me-2"></i>GOV verknüpft</h5></div>'
                    + '<div class="modal-body"><p><strong>' + (data.name || data.gov_id) + '</strong></p>'
                    + (data.lat ? '<p class="small text-muted">Koord.: ' + data.lat.toFixed(4) + ', ' + data.lng.toFixed(4) + '</p>' : '')
                    + '</div><div class="modal-footer">'
                    + '<button class="btn btn-primary" onclick="location.reload()">Liste neu laden</button></div>';
            } else {
                content.innerHTML = '<div class="modal-header"><h5 class="modal-title text-danger">Fehler</h5></div>'
                    + '<div class="modal-body"><div class="alert alert-danger">' + data.message + '</div></div>'
                    + '<div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Schließen</button></div>';
            }
        })
        .catch(err => alert('Netzwerkfehler: ' + err));
    });
    document.addEventListener('click', function (e) {
        if (e.target.id !== 'ortsregister-gov-unlink' && !e.target.closest?.('#ortsregister-gov-unlink')) return;
        const form = document.getElementById('ortsregister-gov-form');
        const fd = new FormData(form);
        fd.append('unlink', '1');
        fetch(form.action, { method: 'POST', body: fd, headers: { 'X-CSRF-TOKEN': table.dataset.csrf }})
            .then(r => r.json())
            .then(_ => location.reload());
    });

    // ---- Merge-Modus-Toggle ----
    // Auswahl-Spalte ist initial versteckt (visible:false oben).
    // Toggle macht sie sichtbar + zeigt aktiven Status visuell.
    document.getElementById('ortsregister-merge-mode-toggle').addEventListener('click', function () {
        const col = dt.api().column(0);
        const visible = !col.visible();
        col.visible(visible);
        this.classList.toggle('active', visible);
        this.classList.toggle('btn-secondary', visible);
        this.classList.toggle('btn-outline-secondary', !visible);
        if (!visible) {
            // Beim Ausblenden auch State zurücksetzen
            mergeState.srcId = null;
            mergeState.dstId = null;
            updateBar();
        }
    });

    // ---- Hierarchie-Filter-Toggle ----
    document.querySelectorAll('.ortsregister-filter-mode').forEach(function (radio) {
        radio.addEventListener('change', function () {
            const url = radio.closest('[data-filter-mode-url]').dataset.filterModeUrl;
            const fd = new FormData();
            fd.append('_csrf', table.dataset.csrf);
            fd.append('mode', radio.value);
            fetch(url, {
                method: 'POST',
                body: fd,
                headers: { 'X-CSRF-TOKEN': table.dataset.csrf },
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    dt.api().ajax.reload();
                    updateEndorteHint();
                } else {
                    alert('Fehler beim Setzen des Filters: ' + (data.message || 'unbekannt'));
                }
            })
            .catch(err => alert('Netzwerkfehler: ' + err));
        });
    });

    // ---- Endorte-Hinweis: nur bei „Nur Endorte", schließbar + per-Browser gemerkt ----
    const endorteHint = document.getElementById('ortsregister-endorte-hint');
    const ENDORTE_HINT_KEY = 'ortsregister-endorte-hint-hidden';
    function updateEndorteHint() {
        if (!endorteHint) return;
        const checked = document.querySelector('.ortsregister-filter-mode:checked');
        const isLeaves = checked && checked.value === 'leaves';
        let dismissed = false;
        try { dismissed = localStorage.getItem(ENDORTE_HINT_KEY) === '1'; } catch (e) {}
        endorteHint.style.display = (isLeaves && !dismissed) ? '' : 'none';
    }
    if (endorteHint) {
        const closeBtn = endorteHint.querySelector('.ortsregister-hint-close');
        if (closeBtn) {
            closeBtn.addEventListener('click', function () {
                try { localStorage.setItem(ENDORTE_HINT_KEY, '1'); } catch (e) {}
                updateEndorteHint();
            });
        }
    }
    updateEndorteHint();

    // ---- Merge-Selection State ----
    const mergeState = { srcId: null, dstId: null };

    function updateBar() {
        const bar = document.getElementById('ortsregister-merge-bar');
        const srcLbl = document.getElementById('ortsregister-src-label');
        const dstLbl = document.getElementById('ortsregister-dst-label');
        const btn = document.getElementById('ortsregister-open-merge-btn');

        const hasAny = mergeState.srcId !== null || mergeState.dstId !== null;
        bar.classList.toggle('d-none', !hasAny);

        srcLbl.textContent = mergeState.srcId !== null ? mergeState.srcId : '—';
        dstLbl.textContent = mergeState.dstId !== null ? mergeState.dstId : '—';

        const bothSet = mergeState.srcId !== null && mergeState.dstId !== null;
        const sameRow = mergeState.srcId === mergeState.dstId;
        btn.disabled = !bothSet || sameRow;
    }

    function restoreSelectionRadios() {
        document.querySelectorAll('.ortsregister-src').forEach(r => {
            r.checked = (parseInt(r.value, 10) === mergeState.srcId);
        });
        document.querySelectorAll('.ortsregister-dst').forEach(r => {
            r.checked = (parseInt(r.value, 10) === mergeState.dstId);
        });
    }

    // Event-Delegation auf den Table-Body — überlebt Re-Renders durch DataTables
    table.addEventListener('change', function (e) {
        if (e.target.classList.contains('ortsregister-src')) {
            mergeState.srcId = parseInt(e.target.value, 10);
            updateBar();
        } else if (e.target.classList.contains('ortsregister-dst')) {
            mergeState.dstId = parseInt(e.target.value, 10);
            updateBar();
        }
    });

    document.getElementById('ortsregister-clear-btn').addEventListener('click', function () {
        mergeState.srcId = null;
        mergeState.dstId = null;
        restoreSelectionRadios();
        updateBar();
    });

    // ---- Modal öffnen + AJAX-Laden ----
    // Korrekter Query-Separator: ? wenn URL bisher keinen hat, sonst &.
    // Bei nicht-aktivierten Pretty-URLs enthaelt route() bereits 'index.php?route=...'.
    function appendQuery(base, qs) {
        return base + (base.indexOf('?') >= 0 ? '&' : '?') + qs;
    }

    document.getElementById('ortsregister-open-merge-btn').addEventListener('click', function () {
        const url = appendQuery(table.dataset.mergePreview,
            'src=' + mergeState.srcId + '&dst=' + mergeState.dstId);
        const content = document.getElementById('ortsregister-merge-modal-content');
        content.innerHTML = '<div class="modal-body text-center py-5"><div class="spinner-border text-primary"></div></div>';
        const modal = new bootstrap.Modal(document.getElementById('ortsregister-merge-modal'));
        modal.show();
        fetch(url, { headers: { 'Accept': 'text/html' }})
            .then(r => r.text())
            .then(html => { content.innerHTML = html; })
            .catch(err => {
                content.innerHTML = '<div class="modal-body text-danger">Fehler beim Laden: ' + err + '</div>';
            });
    });

    // ---- Confirm im Modal -> POST ----
    document.addEventListener('click', function (e) {
        if (e.target.id !== 'ortsregister-merge-confirm' && !e.target.closest?.('#ortsregister-merge-confirm')) {
            return;
        }
        const btn = e.target.closest('#ortsregister-merge-confirm');
        btn.disabled = true;

        // Resolutions einsammeln (alle ortsregister-resolve-Radios)
        const resolutions = {};
        document.querySelectorAll('.ortsregister-resolve:checked').forEach(r => {
            const tag = r.name.replace(/^res__/, '');
            resolutions[tag] = r.value;
        });

        const formData = new FormData();
        formData.append('_csrf', table.dataset.csrf);
        formData.append('src', btn.dataset.src);
        formData.append('dst', btn.dataset.dst);
        for (const k in resolutions) {
            formData.append('resolutions[' + k + ']', resolutions[k]);
        }

        fetch(table.dataset.mergeExecute, {
            method: 'POST',
            body: formData,
            headers: { 'X-CSRF-TOKEN': table.dataset.csrf },
        })
        .then(r => r.json())
        .then(data => {
            const content = document.getElementById('ortsregister-merge-modal-content');
            if (data.success) {
                content.innerHTML = '<div class="modal-header"><h5 class="modal-title text-success">'
                    + '<i class="fas fa-check me-2"></i>Merge erfolgreich</h5></div>'
                    + '<div class="modal-body"><p>' + data.message + '</p></div>'
                    + '<div class="modal-footer">'
                    + '<button class="btn btn-outline-danger ortsregister-merge-undo" data-log-id="' + (data.log_id || '') + '">'
                    + '<i class="fas fa-arrow-left me-1"></i>Rückgängig</button>'
                    + '<button class="btn btn-primary" onclick="location.reload()">Liste neu laden</button></div>';
                // State zurücksetzen
                mergeState.srcId = null; mergeState.dstId = null;
            } else {
                content.innerHTML = '<div class="modal-header"><h5 class="modal-title text-danger">'
                    + '<i class="fas fa-exclamation-triangle me-2"></i>Merge fehlgeschlagen</h5></div>'
                    + '<div class="modal-body"><div class="alert alert-danger">' + data.message + '</div></div>'
                    + '<div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Schließen</button></div>';
            }
        })
        .catch(err => {
            btn.disabled = false;
            alert('Netzwerkfehler: ' + err);
        });
    });

    // ---- Umbenennen-Button öffnet Modal ----
    table.addEventListener('click', function (e) {
        const btn = e.target.closest('.ortsregister-rename-btn');
        if (!btn) return;
        const placeId = btn.dataset.placeId;
        const url = appendQuery(table.dataset.renamePreview, 'place_id=' + placeId);
        const content = document.getElementById('ortsregister-merge-modal-content');
        content.innerHTML = '<div class="modal-body text-center py-5"><div class="spinner-border text-primary"></div></div>';
        new bootstrap.Modal(document.getElementById('ortsregister-merge-modal')).show();
        fetch(url, { headers: { 'Accept': 'text/html' }})
            .then(r => r.text())
            .then(html => { content.innerHTML = html; })
            .catch(err => { content.innerHTML = '<div class="modal-body text-danger">Fehler: ' + err + '</div>'; });
    });

    // ---- Umbenennen bestätigen -> POST ----
    document.addEventListener('click', function (e) {
        const btn = e.target.closest('#ortsregister-rename-confirm');
        if (!btn) return;
        const input = document.getElementById('ortsregister-rename-input');
        const newValue = input ? input.value.trim() : '';
        if (newValue === '') { alert('Bitte einen Namen eingeben.'); return; }
        if (newValue === btn.dataset.oldName) { alert('Der Name ist unverändert.'); return; }
        btn.disabled = true;

        const fd = new FormData();
        fd.append('_csrf', table.dataset.csrf);
        fd.append('src', btn.dataset.placeId);
        fd.append('new_value', newValue);

        fetch(table.dataset.renameExecute, {
            method: 'POST',
            body: fd,
            headers: { 'X-CSRF-TOKEN': table.dataset.csrf },
        })
        .then(r => r.json())
        .then(data => {
            const content = document.getElementById('ortsregister-merge-modal-content');
            if (data.success) {
                content.innerHTML = '<div class="modal-header"><h5 class="modal-title text-success">'
                    + '<i class="fas fa-check me-2"></i>Umbenannt</h5></div>'
                    + '<div class="modal-body"><p>' + data.message + '</p></div>'
                    + '<div class="modal-footer">'
                    + '<button class="btn btn-outline-danger ortsregister-merge-undo" data-log-id="' + (data.log_id || '') + '">'
                    + '<i class="fas fa-arrow-left me-1"></i>Rückgängig</button>'
                    + '<button class="btn btn-primary" onclick="location.reload()">Liste neu laden</button></div>';
            } else {
                content.innerHTML = '<div class="modal-header"><h5 class="modal-title text-danger">'
                    + '<i class="fas fa-exclamation-triangle me-2"></i>Umbenennen fehlgeschlagen</h5></div>'
                    + '<div class="modal-body"><div class="alert alert-danger">' + data.message + '</div></div>'
                    + '<div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Schließen</button></div>';
            }
        })
        .catch(err => {
            btn.disabled = false;
            alert('Netzwerkfehler: ' + err);
        });
    });

    // ---- Merge rückgängig (Event-Delegation, überlebt Modal-Re-Render) ----
    document.addEventListener('click', function (e) {
        const undoBtn = e.target.closest('.ortsregister-merge-undo');
        if (!undoBtn) return;
        const logId = undoBtn.dataset.logId;
        if (!logId) {
            alert('Kein Log-Eintrag für diesen Merge — Undo nicht möglich.');
            return;
        }
        undoBtn.disabled = true;

        const fd = new FormData();
        fd.append('_csrf', table.dataset.csrf);
        fd.append('log_id', logId);

        fetch(table.dataset.mergeUndo, {
            method: 'POST',
            body: fd,
            headers: { 'X-CSRF-TOKEN': table.dataset.csrf },
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                // Funktioniert aus dem Merge-Popup UND aus der Verlaufsliste:
                // neu laden → Ort ist zurück, Verlaufszeile zeigt „rückgängig gemacht".
                location.reload();
            } else {
                // Wichtig: Stale-Abbruch-Meldung sichtbar machen (kein stiller Fehlschlag).
                undoBtn.disabled = false;
                alert(data.message || 'Rückgängig fehlgeschlagen.');
            }
        })
        .catch(err => {
            undoBtn.disabled = false;
            alert('Undo fehlgeschlagen: ' + err);
        });
    });
});
</script>
<?php endif ?>
