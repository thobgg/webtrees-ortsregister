$kartenUrl     = e(route('ortsregister.orte.karte', ['tree' => $tree?->name()]));
$mergePreview  = e(route('ortsregister.merge.preview', ['tree' => $tree?->name()]));
$mergeExecute  = e(route('ortsregister.merge.execute', ['tree' => $tree?->name()]));
?>

