<?php

/**
 * View: ortsregister::orte  (DataTables + Karten-Tab)
 * Route: GET /tree/{tree}/orte
 *
 * @var string                              $title
 * @var \Fisharebest\Webtrees\Tree|null     $tree
 */

use Fisharebest\Webtrees\I18N;

$ajaxUrl   = e(route('ortsregister.orte.data', ['tree' => $tree?->name()]));
$kartenUrl = e(route('ortsregister.orte.karte', ['tree' => $tree?->name()]));
?>

<div class="container-lg mt-4 mb-5" id="ortsregister-orte">

    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item active" aria-current="page"><?= I18N::translate('Ortsregister') ?></li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0"><?= e($title) ?></h1>
        <?php if ($tree !== null) : ?>
            <a href="<?= $kartenUrl ?>" class="btn btn-outline-primary btn-sm">
                <i class="fas fa-map me-1"></i><?= I18N::translate('Kartenansicht') ?>
            </a>
        <?php endif ?>
    </div>

    <?php if ($tree === null) : ?>
        <div class="alert alert-warning"><?= I18N::translate('Bitte wählen Sie einen Stammbaum aus.') ?></div>
    <?php else : ?>

        <div class="table-responsive">
            <table id="orte-datatable"
                   class="table table-hover table-striped w-100"
                   data-ajax="<?= $ajaxUrl ?>">
                <thead class="table-light">
                    <tr>
                        <th><?= I18N::translate('Ort') ?></th>
                        <th style="width:10%"><?= I18N::translate('Ereignisse') ?></th>
                        <th style="width:8%"><?= I18N::translate('Koordinaten') ?></th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

    <?php endif ?>

</div>

<?php if ($tree !== null) : ?>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const table = document.getElementById('orte-datatable');
    if (!table || typeof $.fn.dataTable === 'undefined') return;

    $(table).dataTable({
        ajax:       { url: table.dataset.ajax, type: 'GET' },
        serverSide: true,
        processing: true,
        language: {
            search:      '<?= e(I18N::translate('Suchen:')) ?>',
            lengthMenu:  '<?= e(I18N::translate('_MENU_ Einträge')) ?>',
            info:        '<?= e(I18N::translate('_START_–_END_ von _TOTAL_')) ?>',
            infoEmpty:   '<?= e(I18N::translate('Keine Einträge')) ?>',
            zeroRecords: '<?= e(I18N::translate('Keine Treffer')) ?>',
            processing:  '<?= e(I18N::translate('Wird geladen …')) ?>',
            paginate: { first: '«', last: '»', next: '›', previous: '‹' },
        },
        columns: [
            { orderable: true,  searchable: true  },
            { orderable: true,  searchable: false, className: 'text-end' },
            { orderable: false, searchable: false, className: 'text-center' },
        ],
        order:      [[0, 'asc']],
        pageLength: 50,
        lengthMenu: [10, 25, 50, 100],
        dom: '<"d-flex justify-content-between mb-2"lf>rt<"d-flex justify-content-between mt-2"ip>',
    });
});
</script>
<?php endif ?>
