        <div class="table-responsive">
            <table id="orte-datatable"
                   class="table table-hover table-striped w-100"
                   data-ajax="<?= $ajaxUrl ?>"
                   data-merge-preview="<?= $mergePreview ?>"
                   data-merge-execute="<?= $mergeExecute ?>">
                <thead class="table-light">
                    <tr>
                        <th style="width:6%"><?= I18N::translate('Auswahl') ?></th>
                        <th><?= I18N::translate('Ort') ?></th>
                        <th style="width:10%"><?= I18N::translate('Ereignisse') ?></th>
                        <th style="width:8%"><?= I18N::translate('Koordinaten') ?></th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>

        <!-- Modal-Container für Merge-Vorschau (Inhalt wird per AJAX geladen) -->
        <div class="modal fade" id="ortsregister-merge-modal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content" id="ortsregister-merge-modal-content">
                    <div class="modal-body text-center py-5">
                        <div class="spinner-border text-primary"></div>
                    </div>
                </div>
            </div>
