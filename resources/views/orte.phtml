        <!-- Merge-Selection-Bar -->
        <div id="ortsregister-merge-bar" class="alert alert-info d-none mb-3 d-flex align-items-center justify-content-between">
            <div class="small">
                <i class="fas fa-info-circle me-1"></i>
                <strong><?= I18N::translate('Merge-Auswahl:') ?></strong>
                <span class="ms-2"><?= I18N::translate('Quelle') ?>: <code id="ortsregister-src-label">—</code></span>
                <span class="ms-2"><?= I18N::translate('Ziel') ?>: <code id="ortsregister-dst-label">—</code></span>
            </div>
            <div>
                <button type="button" class="btn btn-sm btn-outline-secondary me-2" id="ortsregister-clear-btn">
                    <i class="fas fa-times me-1"></i><?= I18N::translate('Auswahl löschen') ?>
                </button>
                <button type="button" class="btn btn-sm btn-primary" id="ortsregister-open-merge-btn" disabled>
                    <i class="fas fa-code-branch me-1"></i><?= I18N::translate('Mergen…') ?>
                </button>
            </div>
