                    // Zeitspanne als "1806–1813" / "ab 1806" / "bis 1813" / "" formatieren
                    $formatSpan = static function (?string $begin, ?string $end): string {
                        $b = $begin !== null && $begin !== '' ? trim($begin) : '';
                        $e = $end   !== null && $end   !== '' ? trim($end)   : '';
                        if ($b === '' && $e === '') return '';
                        if ($b !== '' && $e !== '') return $b . '–' . $e;
                        if ($b !== '')              return 'ab ' . $b;
                        return 'bis ' . $e;
                    };
                    // Wenn die UNMITTELBARE Elternstufe eine Zeitspanne hat,
                    // ist sie der prägnanteste Epochen-Hinweis fürs Lead.
                    $leadEpoch = '';
                    if (isset($gov_chain[1])) {
                        $leadEpoch = $formatSpan($gov_chain[1]['begin'], $gov_chain[1]['end']);
                    }
