$sonstige = [];
foreach ($medien as $medium) {
    if ($medium->firstImageFile() !== null) {
        $bilder[] = $medium;
    } else {
        $sonstige[] = $medium;
    }
}

// Headerbild: NUR Medien mit "-Fo-" im Dateinamen (= explizit kuratiert
// als Ortsfoto). Kein „erstes Bild aus Liste"-Fallback mehr — das hat
// Personen-/Familienfotos durchgereicht. Wenn kein -Fo- da: Wikipedia P18
