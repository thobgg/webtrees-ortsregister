                <?php
                $formatSpan = static function (?string $begin, ?string $end): string {
                    $b = $begin !== null && $begin !== '' ? trim($begin) : '';
                    $e = $end   !== null && $end   !== '' ? trim($end)   : '';
                    if ($b === '' && $e === '') return '';
                    if ($b !== '' && $e !== '') return $b . '–' . $e;
                    if ($b !== '')              return 'ab ' . $b;
                    return 'bis ' . $e;
                };
                $renderChain = function (array $chain, bool $showSpans) use ($formatSpan): string {
                    ob_start(); ?>
                    <ol class="breadcrumb mb-2" style="font-size: 1.05em;">
                        <?php foreach (array_reverse($chain) as $i => $node) : ?>
                            <?php
                            $span = $showSpans ? $formatSpan($node['begin'], $node['end']) : '';
                            $isLast = $i === count($chain) - 1;
                            ?>
                            <li class="breadcrumb-item<?= $isLast ? ' active' : '' ?>">
                                <a href="https://gov.genealogy.net/item/show/<?= e($node['gov_id']) ?>"
                                   target="_blank" rel="noopener" title="<?= e($node['gov_id']) ?>">
                                    <?= e($node['name']) ?>
                                </a>
                                <?php if ($span !== '') : ?>
                                    <small class="text-muted ms-1">(<?= e($span) ?>)</small>
                                <?php endif ?>
                            </li>
                        <?php endforeach ?>
                    </ol>
                    <?php
                    return (string) ob_get_clean();
                };
                // Kette gilt nur als "brauchbar" wenn sie mehr als 1 Element hat
                // (1 Element = nur das Blatt selbst, keine Eltern — zeigt keine Hierarchie).
                $hasHistorical = count($gov_chain)         > 1;
