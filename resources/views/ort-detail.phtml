<script>
(function () {
    const modalEl    = document.getElementById('ortsregister-notes-modal');
    if (!modalEl) return;
    const saveUrl    = modalEl.dataset.saveUrl;
    const csrf       = modalEl.dataset.csrf;
    const textarea   = document.getElementById('ortsregister-notes-textarea');
    const mtimeEl    = document.getElementById('ortsregister-notes-mtime');
    const filenameEl = document.getElementById('ortsregister-notes-filename');
    const titlePrefix= document.getElementById('ortsregister-notes-title-prefix');
    const fileEcho   = document.getElementById('ortsregister-notes-fileecho');
    const status     = document.getElementById('ortsregister-notes-status');
    const saveBtn    = document.getElementById('ortsregister-notes-save');

    let bsModal = null;
    const getModal = () => {
        if (bsModal === null) {
            if (typeof bootstrap === 'undefined') throw new Error('Bootstrap-JS noch nicht geladen.');
            bsModal = new bootstrap.Modal(modalEl);
        }
        return bsModal;
    };

    // Event-Delegation: jeder .ortsregister-notes-edit-btn füllt das Modal aus seinen data-* Attributen
    document.addEventListener('click', function (e) {
        const btn = e.target.closest('.ortsregister-notes-edit-btn');
        if (!btn) return;
        const filename    = btn.dataset.filename    || 'notes.md';
        filenameEl.value          = filename;
        mtimeEl.value             = btn.dataset.mtime       || '0';
        textarea.value            = btn.dataset.markdown    || '';
        textarea.placeholder      = btn.dataset.placeholder || '';
        titlePrefix.textContent   = (btn.dataset.title || 'Notizen') + ' bearbeiten';
        fileEcho.textContent      = filename;
        status.textContent        = '';

        // Personen-Picker nur in Slots zeigen die das brauchen (Recherche etc.)
        const pickerWrap = document.getElementById('ortsregister-indi-picker-wrap');
        if (pickerWrap) {
            pickerWrap.style.display = (btn.dataset.personPicker === '1') ? '' : 'none';
        }
        try { getModal().show(); }
        catch (err) { console.error('[ortsregister] notes-modal show failed:', err); alert('Modal-Fehler: ' + err.message); }
    });

    saveBtn.addEventListener('click', () => {
        saveBtn.disabled   = true;
        status.textContent = '…';
        const filename = filenameEl.value;
        const fd = new FormData();
        fd.append('markdown', textarea.value);
        fd.append('mtime',    mtimeEl.value);
        fd.append('filename', filename);
        fetch(saveUrl, { method: 'POST', body: fd, headers: { 'X-CSRF-TOKEN': csrf }})
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    mtimeEl.value = data.mtime;
                    const display = document.querySelector('[data-notes-display="' + filename + '"]');
                    if (display) {
                        display.innerHTML = data.html || '<p class="text-muted mb-0 fst-italic">Noch leer.</p>';
                        initCheckboxes(display);
                    }
                    const btn = document.querySelector('.ortsregister-notes-edit-btn[data-filename="' + filename + '"]');
                    if (btn) {
                        btn.dataset.markdown = data.markdown || textarea.value;
                        btn.dataset.mtime    = data.mtime;
                    }
                    getModal().hide();
                } else {
                    status.innerHTML = '<span class="text-danger">' + (data.message || 'Fehler') + '</span>';
                }
            })
            .catch(err => { status.innerHTML = '<span class="text-danger">Netzwerkfehler: ' + err + '</span>'; })
            .finally(() => { saveBtn.disabled = false; });
    });

    // ---- Interaktive Task-Checkboxen ----
    const toggleUrl = modalEl.dataset.toggleUrl;

    function initCheckboxes(display) {
        const filename = display.dataset.notesDisplay;
        display.querySelectorAll('input.ortsregister-task-cb[type="checkbox"]').forEach(cb => {
            cb.style.cursor = 'pointer';
            cb.addEventListener('change', () => {
                const idx = cb.dataset.taskIndex;
                cb.disabled = true;
                const fd = new FormData();
                fd.append('filename',   filename);
                fd.append('task_index', idx);
                fd.append('checked',    cb.checked ? '1' : '0');
                fetch(toggleUrl, { method: 'POST', body: fd, headers: { 'X-CSRF-TOKEN': csrf }})
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            display.innerHTML = data.html;
                            initCheckboxes(display);
                            const btn = document.querySelector('.ortsregister-notes-edit-btn[data-filename="' + filename + '"]');
                            if (btn) {
                                btn.dataset.markdown = data.markdown;
                                btn.dataset.mtime    = data.mtime;
                            }
                        } else {
                            cb.checked = !cb.checked;
                            cb.disabled = false;
                            alert('Toggle fehlgeschlagen: ' + (data.message || 'unbekannt'));
                        }
                    })
                    .catch(err => {
                        cb.checked = !cb.checked;
                        cb.disabled = false;
                        alert('Netzwerkfehler: ' + err);
                    });
            });
        });
    }
    document.querySelectorAll('[data-notes-display]').forEach(initCheckboxes);

    // ---- Person einfügen (webtrees TomSelect-Picker) ----
    const indiPicker = document.getElementById('ortsregister-indi-picker');
    if (indiPicker) {
        function insertAtCursor(el, text) {
            const start = el.selectionStart ?? el.value.length;
            const end   = el.selectionEnd   ?? el.value.length;
            el.value    = el.value.substring(0, start) + text + el.value.substring(end);
            el.selectionStart = el.selectionEnd = start + text.length;
            el.focus();
        }
        indiPicker.addEventListener('change', function () {
            const xref = indiPicker.value;
            if (!xref) return;
            // Label aus tom-select holen (rendered HTML), Tags strippen, Lifespan abschneiden
            let name = xref;
            const ts = indiPicker.tomselect;
            if (ts && ts.options[xref] && ts.options[xref].text) {
                const tmp = document.createElement('div');
                tmp.innerHTML = ts.options[xref].text;
                name = tmp.textContent.trim().replace(/,\s*\d.*$/, ''); // Lifespan ", 1850-1923" weg
            }
            insertAtCursor(textarea, '[' + name + '](indi:' + xref + ')');
            if (ts) ts.clear();
        });
    }
})();
</script>
<?php endif ?>

