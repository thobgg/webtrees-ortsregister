<script>
// Tasks-Card Interaktion (Add / Toggle / Edit / Delete)
(function () {
    const card = document.querySelector('.ortsregister-tasks-card');
    if (!card) return;
    const tasksUrl = card.dataset.tasksUrl;
    const csrf     = card.dataset.csrf;
    const list     = card.querySelector('.ortsregister-tasks-list');
    const counter  = card.querySelector('.ortsregister-tasks-counter');
    const addForm  = card.querySelector('.ortsregister-task-add-form');
    const addInput = card.querySelector('.ortsregister-task-add-input');

    async function send(action, params) {
        const fd = new FormData();
        fd.append('action', action);
        for (const k in params) fd.append(k, params[k]);
        const r = await fetch(tasksUrl, { method: 'POST', body: fd, headers: { 'X-CSRF-TOKEN': csrf }});
        return r.json();
    }

    function renderTasks(tasks, counts) {
        list.innerHTML = '';
        if (tasks.length === 0) {
            const empty = document.createElement('li');
            empty.className = 'list-group-item text-muted fst-italic small';
            empty.textContent = 'Noch keine Aufgaben.';
            list.appendChild(empty);
        } else {
            tasks.forEach(t => {
                const open = t.status === 'open';
                const li = document.createElement('li');
                li.className = 'list-group-item d-flex align-items-center gap-2 ortsregister-task';
                li.dataset.id = t.id;

                const cb = document.createElement('input');
                cb.type = 'checkbox';
                cb.className = 'form-check-input mt-0 ortsregister-task-toggle';
                if (!open) cb.checked = true;
                li.appendChild(cb);

                const span = document.createElement('span');
                span.className = 'ortsregister-task-text flex-grow-1' + (open ? '' : ' text-muted text-decoration-line-through');
                span.setAttribute('role', 'button');
                span.title = 'Click zum Bearbeiten';
                span.textContent = t.text;
                li.appendChild(span);

                const meta = (t.created || '') + (t.author ? ' · ' + t.author : '');
                if (meta) {
                    const date = document.createElement('small');
                    date.className = 'text-muted ortsregister-task-date';
                    date.textContent = meta;
                    li.appendChild(date);
                }

                const del = document.createElement('button');
                del.type = 'button';
                del.className = 'btn btn-sm btn-link text-danger p-0 ortsregister-task-delete';
                del.style.opacity = '0';
                del.style.transition = 'opacity .15s';
                del.title = 'Löschen';
                del.textContent = '×';
                li.appendChild(del);

                list.appendChild(li);
            });
        }
        counter.textContent = counts.open + ' offen' + (counts.done > 0 ? ' / ' + counts.done + ' erl.' : '');
    }

    async function handleResponse(data) {
        if (!data.success) {
            alert(data.message || 'Fehler');
            return;
        }
        renderTasks(data.tasks, data.counts);
    }

    if (addForm) {
        addForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const text = addInput.value.trim();
            if (text === '') return;
            await handleResponse(await send('add', { text }));
            addInput.value = '';
            addInput.focus();
        });
    }

    list.addEventListener('change', async (e) => {
        const cb = e.target.closest('.ortsregister-task-toggle');
        if (!cb) return;
        const li = cb.closest('.ortsregister-task');
        await handleResponse(await send('toggle', { id: li.dataset.id }));
    });

    list.addEventListener('click', async (e) => {
        const del = e.target.closest('.ortsregister-task-delete');
        if (del) {
            const li = del.closest('.ortsregister-task');
            if (!confirm('Aufgabe wirklich löschen?')) return;
            await handleResponse(await send('delete', { id: li.dataset.id }));
            return;
        }
        const span = e.target.closest('.ortsregister-task-text[role="button"]');
        if (span && !span.dataset.editing) {
            const li = span.closest('.ortsregister-task');
            const oldText = span.textContent;
            const input = document.createElement('input');
            input.type = 'text';
            input.className = 'form-control form-control-sm flex-grow-1';
            input.value = oldText;
            span.dataset.editing = '1';
            span.replaceWith(input);
            input.focus();
            input.select();
            const commit = async (save) => {
                const newText = input.value.trim();
                if (save && newText !== '' && newText !== oldText) {
                    await handleResponse(await send('edit', { id: li.dataset.id, text: newText }));
                } else {
                    input.replaceWith(span);
                    delete span.dataset.editing;
                }
            };
            input.addEventListener('keydown', (ev) => {
                if (ev.key === 'Enter')  { ev.preventDefault(); commit(true); }
                if (ev.key === 'Escape') { commit(false); }
            });
            input.addEventListener('blur', () => commit(true));
        }
    });
})();
</script>
<?php endif ?>

