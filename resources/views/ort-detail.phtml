/**
 * Format-Klassifikation für Medien-Badges. Übernommen aus
 * sammlungen/_weitere-medien.phtml. Liefert [Badge-Hintergrundfarbe,
 * FA-Icon-Klasse oder null, Kurztext oder null].
 *
 * Hinweis: webtrees bündelt nur ein FA-Subset — sicher sind fa-play,
 * fa-file-lines, fa-file. Andere Icons würden als ?/!-Platzhalter erscheinen.
 */
$medienKategorie = static function (string $ext): array {
    $video = ['mp4', 'avi', 'mov', 'webm', 'mkv', 'm4v', 'mpg', 'mpeg', 'wmv'];
    $audio = ['mp3', 'wav', 'ogg', 'm4a', 'flac', 'aac', 'wma'];
    $word  = ['doc', 'docx', 'odt', 'rtf'];
    $excel = ['xls', 'xlsx', 'ods', 'csv'];
    return match (true) {
        $ext === 'pdf'                => ['#CC0000', null, 'PDF'],
        in_array($ext, $video, true)  => ['#6f42c1', 'fa-play', null],
        in_array($ext, $audio, true)  => ['#0d6efd', 'fa-play', null],
        in_array($ext, $word, true)   => ['#2b579a', 'fa-file-lines', null],
        in_array($ext, $excel, true)  => ['#217346', 'fa-file-lines', null],
        default                       => ['#6c757d', 'fa-file', null],
    };
};

/** Extrahiert die Dateiendung des ersten MediaFile eines webtrees-Mediums. */
$medienEndung = static function (Media $medium): string {
    $files = $medium->mediaFiles();
    $first = $files->first();
    if ($first === null) {
        return '';
    }
    return strtolower(pathinfo((string) $first->filename(), PATHINFO_EXTENSION));
};

// Bilder von Nicht-Bildern trennen
