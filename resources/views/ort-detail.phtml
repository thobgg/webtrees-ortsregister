<script>
// ---- KB-Kacheln Phase 3T ----
(function () {
    const card = document.querySelector('.ortsregister-kbs-card');
    if (!card) return;
    const kbsUrl = card.dataset.kbsUrl;
    const csrf   = card.dataset.csrf;

    const editModalEl = document.getElementById('ortsregister-kb-edit-modal');
    const logModalEl  = document.getElementById('ortsregister-kb-log-modal');
    let bsEdit = null, bsLog = null;
    const getEdit = () => bsEdit ??= new bootstrap.Modal(editModalEl);
    const getLog  = () => bsLog  ??= new bootstrap.Modal(logModalEl);

    // Edit-Form-Refs
    const fId        = document.getElementById('ortsregister-kb-edit-id');
    const fTitle     = document.getElementById('ortsregister-kb-edit-title');
    const fType      = document.getElementById('ortsregister-kb-edit-type');
    const fYearFrom  = document.getElementById('ortsregister-kb-edit-year-from');
    const fYearTo    = document.getElementById('ortsregister-kb-edit-year-to');
    const fArchion   = document.getElementById('ortsregister-kb-edit-archion-url');
    const fSour      = document.getElementById('ortsregister-kb-edit-sour');
    const titleSuffix= document.getElementById('ortsregister-kb-edit-title-suffix');
    const editStatus = document.getElementById('ortsregister-kb-edit-status');
    const saveBtn    = document.getElementById('ortsregister-kb-edit-save');

    // Log-Modal-Refs
    const logId       = document.getElementById('ortsregister-kb-log-id');
    const logTextarea = document.getElementById('ortsregister-kb-log-textarea');
    const logTitleSuf = document.getElementById('ortsregister-kb-log-title-suffix');
    const logStatus   = document.getElementById('ortsregister-kb-log-status');
    const logSaveBtn  = document.getElementById('ortsregister-kb-log-save');

    function fillEditForm(data) {
        fId.value       = data.id || '';
        fTitle.value    = data.title || '';
        fType.value     = data.type || 'sonstige';
        fYearFrom.value = data.year_from || '';
        fYearTo.value   = data.year_to || '';
        fArchion.value  = data.archion_url || '';
        if (fSour.tomselect) fSour.tomselect.clear();
        if (data.sour_xref) {
            if (fSour.tomselect) {
                fSour.tomselect.addOption({ value: data.sour_xref, text: data.sour_xref });
                fSour.tomselect.setValue(data.sour_xref);
            } else {
                fSour.value = data.sour_xref;
            }
        }
        editStatus.textContent = '';
    }

    async function send(action, params) {
        const fd = new FormData();
        fd.append('action', action);
        for (const k in params) fd.append(k, params[k] ?? '');
        const r = await fetch(kbsUrl, { method: 'POST', body: fd, headers: { 'X-CSRF-TOKEN': csrf }});
        return r.json();
    }

    // Add-Button
    card.querySelector('.ortsregister-kb-add-btn')?.addEventListener('click', () => {
        fillEditForm({});
        titleSuffix.textContent = 'neu';
        getEdit().show();
    });

    // Edit / Delete / Log (Event-Delegation auf der Card)
    card.addEventListener('click', async (e) => {
        const tile = e.target.closest('.ortsregister-kb-tile');
        if (!tile) return;
        const editBtn   = e.target.closest('.ortsregister-kb-edit-btn');
        const deleteBtn = e.target.closest('.ortsregister-kb-delete-btn');
        const logBtn    = e.target.closest('.ortsregister-kb-log-btn');

        if (editBtn) {
            fillEditForm({
                id:          tile.dataset.kbId,
                title:       tile.dataset.kbTitle,
                type:        tile.dataset.kbType,
                year_from:   tile.dataset.kbYearFrom,
                year_to:     tile.dataset.kbYearTo,
                archion_url: tile.dataset.kbArchionUrl,
                sour_xref:   tile.dataset.kbSourXref,
            });
            titleSuffix.textContent = tile.dataset.kbTitle.substring(0, 40);
            getEdit().show();
            return;
        }
        if (deleteBtn) {
            if (!confirm('Diesen KB-Eintrag und sein Logbuch wirklich löschen?')) return;
            const data = await send('delete', { id: tile.dataset.kbId });
            if (data.success) location.reload();
            else alert(data.message || 'Fehler');
            return;
        }
        if (logBtn) {
            logId.value = tile.dataset.kbId;
            logTitleSuf.textContent = tile.dataset.kbTitle.substring(0, 40);
            logStatus.textContent = '';
            logTextarea.value = '…';
            const data = await send('read-log', { id: tile.dataset.kbId });
            if (data.success) {
                logTextarea.value = data.markdown || '';
            } else {
                logTextarea.value = '';
                logStatus.innerHTML = '<span class="text-danger">' + (data.message || 'Fehler') + '</span>';
            }
            getLog().show();
        }
    });

    // Save Edit
    saveBtn.addEventListener('click', async () => {
        if (!fTitle.value.trim()) { editStatus.innerHTML = '<span class="text-danger">Titel erforderlich.</span>'; return; }
        saveBtn.disabled = true;
        const action = fId.value === '' ? 'add' : 'edit';
        const params = {
            id:          fId.value,
            title:       fTitle.value,
            type:        fType.value,
            year_from:   fYearFrom.value,
            year_to:     fYearTo.value,
            archion_url: fArchion.value,
            sour_xref:   fSour.value || '',
        };
        try {
            const data = await send(action, params);
            if (data.success) {
                location.reload(); // einfach + zuverlässig — Tile-Daten + Sortierung
            } else {
                editStatus.innerHTML = '<span class="text-danger">' + (data.message || 'Fehler') + '</span>';
            }
        } catch (err) {
            editStatus.innerHTML = '<span class="text-danger">Netzwerkfehler: ' + err + '</span>';
        } finally {
            saveBtn.disabled = false;
        }
    });

    // Save Logbuch
    logSaveBtn.addEventListener('click', async () => {
        logSaveBtn.disabled = true;
        try {
            const data = await send('save-log', { id: logId.value, markdown: logTextarea.value });
            if (data.success) {
                getLog().hide();
                location.reload(); // Indikator "📓 Logbuch" / "📓 Logbuch +" aktualisieren
            } else {
                logStatus.innerHTML = '<span class="text-danger">' + (data.message || 'Fehler') + '</span>';
            }
        } catch (err) {
            logStatus.innerHTML = '<span class="text-danger">Netzwerkfehler: ' + err + '</span>';
        } finally {
            logSaveBtn.disabled = false;
        }
    });
})();
</script>
<?php endif ?>
