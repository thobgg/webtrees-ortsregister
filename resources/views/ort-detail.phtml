        <script>
        document.addEventListener('DOMContentLoaded', function () {
            const el = document.getElementById('ortsregister-detail-map');
            if (!el || typeof L === 'undefined') {
                // Leaflet nicht geladen — Hinweis statt leerer Karte
                if (el) {
                    el.innerHTML = '<div class="p-3 text-muted small">Karte konnte nicht geladen werden (Leaflet-Asset blockiert?). '
                        + 'Koordinaten: <?= e(sprintf('%.4f, %.4f', $ort->breitengrad, $ort->laengengrad)) ?>.</div>';
                }
                return;
            }
            const lat = <?= json_encode($ort->breitengrad) ?>;
            const lon = <?= json_encode($ort->laengengrad) ?>;
            const name = <?= json_encode($ort->name) ?>;
            const map = L.map(el).setView([lat, lon], 13);
            // OSM-DE statt openstreetmap.org — weniger restriktive Rate-Limits
            L.tileLayer('https://tile.openstreetmap.de/{z}/{x}/{y}.png', {
                attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> · <a href="https://www.openstreetmap.de">OSM Deutschland</a>',
                maxZoom: 18,
            }).addTo(map);
            L.marker([lat, lon]).addTo(map).bindPopup('<strong>' + name + '</strong>').openPopup();
        });
        </script>
        <?php View::endpush() ?>
