<script>
// Generischer Collapse-Wrapper: jede Card mit [data-collapsible] wird klickbar im Header,
// State wird per Card-Key in localStorage persistiert (per-User, per-Browser).
(function () {
    const STORAGE_PREFIX = 'ortsregister-card:';
    document.querySelectorAll('[data-collapsible]').forEach(function (card) {
        const key    = card.dataset.cardKey;
        const header = card.querySelector(':scope > .card-header');
        if (!header || !key) return;

        // Chevron einmal anhängen
        if (!header.querySelector('.ortsregister-chevron')) {
            const ch = document.createElement('span');
            ch.className = 'ortsregister-chevron ms-auto';
            ch.textContent = '▼';
            ch.setAttribute('aria-hidden', 'true');
            header.appendChild(ch);
        }

        // Initial-State aus localStorage
        try {
            if (localStorage.getItem(STORAGE_PREFIX + key) === 'collapsed') {
                card.classList.add('ortsregister-collapsed');
            }
        } catch (e) { /* localStorage nicht verfügbar — egal */ }

        header.addEventListener('click', function (e) {
            // Click auf interaktive Header-Kinder (Buttons, Links) nicht abfangen
            if (e.target.closest('a, button, input, select')) return;
            card.classList.toggle('ortsregister-collapsed');
            try {
                localStorage.setItem(
                    STORAGE_PREFIX + key,
                    card.classList.contains('ortsregister-collapsed') ? 'collapsed' : 'expanded'
                );
            } catch (e) { /* still egal */ }
        });
    });
})();
</script>
