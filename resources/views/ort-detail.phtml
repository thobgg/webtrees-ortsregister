<script>
(function () {
    const modalEl = document.getElementById('ortsregister-lightbox');
    if (!modalEl) return;
    const bsModal  = new bootstrap.Modal(modalEl);
    const img      = document.getElementById('ortsregister-lb-img');
    const caption  = document.getElementById('ortsregister-lb-caption');
    const position = document.getElementById('ortsregister-lb-position');
    const link     = document.getElementById('ortsregister-lb-mediaurl');
    const prevBtn  = document.getElementById('ortsregister-lb-prev');
    const nextBtn  = document.getElementById('ortsregister-lb-next');

    let items   = [];
    let current = 0;

    function show(idx) {
        if (!items.length) return;
        current = (idx + items.length) % items.length;
        const it = items[current];
        img.src = it.full;
        img.alt = it.caption;
        caption.textContent  = it.caption;
        position.textContent = (current + 1) + ' / ' + items.length;
        link.href = it.mediaUrl;
    }

    document.addEventListener('click', function (e) {
        const tile = e.target.closest('.ortsregister-gallery-item');
        if (!tile || !tile.dataset.full) return;
        e.preventDefault();
        // Sammle alle Bilder im Card (visible + im collapse)
        const card = tile.closest('.card');
        items = Array.from(card.querySelectorAll('.ortsregister-gallery-item'))
            .filter(el => el.dataset.full)
            .map(el => ({
                full:     el.dataset.full,
                caption:  el.dataset.caption || '',
                mediaUrl: el.dataset.mediaurl || '#',
            }));
        const realIdx = items.findIndex(x => x.full === tile.dataset.full);
        show(realIdx >= 0 ? realIdx : 0);
        bsModal.show();
    });

    prevBtn.addEventListener('click', () => show(current - 1));
    nextBtn.addEventListener('click', () => show(current + 1));

    document.addEventListener('keydown', function (e) {
        if (!modalEl.classList.contains('show')) return;
        if (e.key === 'ArrowLeft')  show(current - 1);
        if (e.key === 'ArrowRight') show(current + 1);
    });

    modalEl.addEventListener('hidden.bs.modal', () => { img.src = ''; });
})();
</script>
<?php endif ?>

<?php if ($ort !== null && $tree !== null) : ?>
<div class="modal fade" id="ortsregister-gov-modal" tabindex="-1" aria-hidden="true"
     data-gov-link="<?= e(route('ortsregister.gov.link', ['tree' => $tree->name()])) ?>"
     data-csrf="<?= e(csrf_token()) ?>">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content" id="ortsregister-gov-modal-content">
            <div class="modal-body text-center py-5"><div class="spinner-border text-primary"></div></div>
        </div>
    </div>
</div>
<script>
(function () {
    const modalEl = document.getElementById('ortsregister-gov-modal');
    if (!modalEl) return;
    const govLinkUrl = modalEl.dataset.govLink;
    const csrf       = modalEl.dataset.csrf;

    const appendQuery = (url, q) => url + (url.includes('?') ? '&' : '?') + q;

    document.addEventListener('click', function (e) {
        const btn = e.target.closest('.ortsregister-gov-btn');
        if (!btn) return;
        const placeId = btn.dataset.placeId;
        const url     = appendQuery(govLinkUrl, 'place_id=' + placeId);
        const content = document.getElementById('ortsregister-gov-modal-content');
        content.innerHTML = '<div class="modal-body text-center py-5"><div class="spinner-border text-primary"></div></div>';
        new bootstrap.Modal(modalEl).show();
        fetch(url, { headers: { 'Accept': 'text/html' }})
            .then(r => r.text())
            .then(html => { content.innerHTML = html; })
            .catch(err => { content.innerHTML = '<div class="modal-body text-danger">Fehler: ' + err + '</div>'; });
    });

    document.addEventListener('submit', function (e) {
        if (e.target.id !== 'ortsregister-gov-form') return;
        e.preventDefault();
        fetch(e.target.action, {
            method: 'POST',
            body: new FormData(e.target),
            headers: { 'X-CSRF-TOKEN': csrf },
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert('GOV-Verknüpfung fehlgeschlagen: ' + (data.message || 'unbekannter Fehler'));
            }
        })
        .catch(err => alert('Netzwerkfehler: ' + err));
    });

    document.addEventListener('click', function (e) {
        if (e.target.id !== 'ortsregister-gov-unlink' && !e.target.closest?.('#ortsregister-gov-unlink')) return;
        const form = document.getElementById('ortsregister-gov-form');
        if (!form) return;
        const fd = new FormData(form);
        fd.append('unlink', '1');
        fetch(form.action, { method: 'POST', body: fd, headers: { 'X-CSRF-TOKEN': csrf }})
            .then(r => r.json())
            .then(_ => location.reload());
    });
})();
</script>
<?php endif ?>
